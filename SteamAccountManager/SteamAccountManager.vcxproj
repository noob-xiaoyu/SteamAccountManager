  <!-- 前端自动构建与同步逻辑 -->
  <Target Name="BuildFrontend" BeforeTargets="PreBuildEvent">
    <Message Text="[SAM] 正在准备前端构建..." Importance="high" />
    <!-- 检查 node_modules，不存在则安装 -->
    <Exec Command="cd /d &quot;$(ProjectDir)..\frontend&quot; &amp;&amp; if not exist node_modules (npm install)" />
    <!-- 执行生产构建 -->
    <Message Text="[SAM] 正在执行 Vite 构建 (npm run build)..." Importance="high" />
    <Exec Command="cd /d &quot;$(ProjectDir)..\frontend&quot; &amp;&amp; npm run build" />
  </Target>
  <!-- 构建完成后同步 dist 到输出目录 -->
  <Target Name="SyncFrontendToOutput" AfterTargets="Build">
    <Message Text="[SAM] 正在同步前端资源到输出目录: $(OutDir)frontend\dist" Importance="high" />
    <ItemGroup>
      <FrontendFiles Include="$(ProjectDir)..\frontend\dist\**\*.*" />
    </ItemGroup>
    <!-- 使用 Copy 任务，强制覆盖（通过设置 SkipUnchangedFiles=false） -->
    <Copy SourceFiles="@(FrontendFiles)" DestinationFolder="$(OutDir)frontend\dist\%(RecursiveDir)" SkipUnchangedFiles="false" />
    <Message Text="[SAM] 前端资源同步完成。" Importance="high" />
  </Target>
